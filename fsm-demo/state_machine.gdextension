[configuration]
entry_symbol = "nodestate_library_init"
compatibility_minimum = "4.2"

[libraries]
macos.debug = "res://bin/node_state_controller/libstate_machine.macos.template_debug.framework"
macos.release = "res://bin/node_state_controller/libstate_machine.macos.template_release.framework"
windows.debug.x86_64 = "res://bin/node_state_controller/libstate_machine.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://bin/node_state_controller/libstate_machine.windows.template_release.x86_64.dll"
linux.debug.x86_64 = "res://bin/node_state_controller/libstate_machine.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://bin/node_state_controller/libstate_machine.linux.template_release.x86_64.so"
android.debug.arm64 = "res://bin/node_state_controller/libstate_machine.android.template_debug.arm64.so"
android.release.arm64 = "res://bin/node_state_controller/libstate_machine.android.template_release.arm64.so"
ios.debug.arm64 = "res://bin/node_state_controller/libstate_machine.ios.template_debug.arm64.dylib"
ios.release.arm64 = "res://bin/node_state_controller/libstate_machine.ios.template_release.arm64.dylib"
web.debug.wasm32 = "res://bin/node_state_controller/libstate_machine.web.template_debug.wasm32.wasm"
web.release.wasm32 = "res://bin/node_state_controller/libstate_machine.web.template_release.wasm32.wasm"